{
  "permissions": {
    "allow": [
      "Bash(python tools/render/render.py:*)",
      "Bash(./.venv/Scripts/python.exe tools/render/render.py:*)",
      "Bash(pip install:*)",
      "Bash(python -m playwright install:*)",
      "Bash(ls:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "env": {
    "PYTHONIOENCODING": "utf-8"
  }
}
