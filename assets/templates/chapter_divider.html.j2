<section class="chapter-divider {{ ch.body_class }}"
         id="ch-{{ ch.num }}-divider"
         style="--accent: {{ chapter_accent[ch.num] }};">
  <div class="divider-rule"></div>
  <p class="divider-eyebrow">CHAPTER {{ ch.num }}</p>
  <h2 class="divider-zh">{{ ch.title_zh }}</h2>
  <p class="divider-en">{{ ch.title_en }}</p>
  <p class="divider-meta">{{ edition_label }}</p>
  <span class="divider-badge">AI-assisted</span>
</section>
